# =============================================================================
# MediScan AI — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/
*.so

# --- Virtual environments ---
venv/
.venv/
env/
.env/
ENV/

# --- Environment variables / secrets ---
.env
.env.local
*.env


# Remove the line above if you want to commit the checkpoint directly.
# For files > 50 MB, use Git LFS instead:
#   git lfs track "models/*.pth"

# --- Dataset (never commit ~2 GB of images) ---
chest_xray/
data/


# Keep the placeholder files so the directories exist in the repo:
!outputs/.gitkeep
!outputs/sample_predictions/.gitkeep

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo